{
  "name": "log10x-mcp",
  "version": "1.4.0",
  "description": "Log10x MCP Server — per-pattern log cost attribution, root-cause investigation, pasted-batch triage, archive query/backfill, and cross-pillar correlation against customer metric backends (Grafana Cloud, Mimir, Thanos, AMP) with structural validation that refuses when it cannot prove linkage",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "log10x-mcp": "build/index.js"
  },
  "files": [
    "build",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && chmod +x build/index.js",
    "start": "node build/index.js",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "test": "tsc -p tsconfig.test.json && node --test test-build/test/",
    "test:integration": "LOG10X_INTEGRATION_TESTS=1 npm test"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "log10x",
    "observability",
    "cost-attribution",
    "logs",
    "claude",
    "anthropic",
    "ai-tools"
  ],
  "author": "Log10x",
  "license": "MIT",
  "homepage": "https://log10x.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/log-10x/log10x-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/log-10x/log10x-mcp/issues"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch-logs": "^3.1032.0",
    "@aws-sdk/credential-providers": "^3.1032.0",
    "@azure/identity": "^4.13.1",
    "@azure/monitor-query": "^1.3.3",
    "@clickhouse/client": "^1.18.2",
    "@datadog/datadog-api-client": "^1.56.0",
    "@elastic/elasticsearch": "^9.3.4",
    "@google-cloud/logging": "^11.2.1",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
