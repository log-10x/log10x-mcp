  "description": "Log10x MCP Server — per-pattern log cost attribution for AI assistants (Claude, Cursor, Claude Desktop)",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "log10x-mcp": "build/index.js"
  },
  "files": [
