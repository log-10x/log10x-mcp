{
  "id": "inject-critical-burst",
  "description": "100 CRITICAL events over 60s from a fake service. Tests that severity_level=CRITICAL bytes jump, the pattern surfaces in error-critical-events scenario, and the agent identifies the canary as the top CRITICAL pattern.",
  "target_env": "talw_gx",
  "generator_spec": {
    "template": "canary critical burst probe payment timeout exceeded ${idx}",
    "severity": "CRITICAL",
    "service": "canary-payments",
    "rate_per_second": 1.67,
    "duration_seconds": 60,
    "extra_tags": {
      "kubernetes.namespace_name": "synthetic-canary",
      "kubernetes.pod_name": "canary-payments-burst"
    }
  },
  "propagation_seconds": 90,
  "sensitive_scenarios": [
    {
      "scenario_id": "error-critical-events",
      "predicted_metric_delta": {
        "severity_bytes_increase_at_least": {
          "severity": "CRITICAL",
          "bytes": 1000
        },
        "service_appears": "canary-payments"
      },
      "predicted_agent_behavior": {
        "must_mention_correlation": ["canary-payments", "CRITICAL"],
        "must_not_fabricate_root_cause": true
      }
    }
  ]
}
