{
  "spec": {
    "template": {
      "spec": {
        "containers": [
          {
            "name": "fluent-bit",
            "image": "fluent/fluent-bit:4.0",
            "imagePullPolicy": "IfNotPresent",
            "resources": {
              "limits": {"cpu": "300m", "memory": "192Mi"},
              "requests": {"cpu": "50m", "memory": "64Mi"}
            },
            "volumeMounts": [
              {"name": "fluent-bit-cwl", "mountPath": "/fluent-bit/etc/fluent-bit.conf", "subPath": "fluent-bit.conf"}
            ]
          }
        ],
        "volumes": [
          {"name": "fluent-bit-cwl", "configMap": {"name": "fluent-bit-cwl"}}
        ]
      }
    }
  }
}
