{
  "id": "find-constant-slots-k8s-audit",
  "description": "K8s audit-style events where apiVersion is always 'audit.k8s.io/v1' and kind is always 'Event' \u2014 find_constant_slots should detect both as constant.",
  "tool": "find_constant_slots",
  "args": {
    "events": [
      "{\"apiVersion\":\"audit.k8s.io/v1\",\"kind\":\"Event\",\"verb\":\"get\",\"user\":\"u1\"}",
      "{\"apiVersion\":\"audit.k8s.io/v1\",\"kind\":\"Event\",\"verb\":\"get\",\"user\":\"u2\"}",
      "{\"apiVersion\":\"audit.k8s.io/v1\",\"kind\":\"Event\",\"verb\":\"post\",\"user\":\"u3\"}",
      "{\"apiVersion\":\"audit.k8s.io/v1\",\"kind\":\"Event\",\"verb\":\"put\",\"user\":\"u4\"}",
      "{\"apiVersion\":\"audit.k8s.io/v1\",\"kind\":\"Event\",\"verb\":\"delete\",\"user\":\"u5\"}",
      "{\"apiVersion\":\"audit.k8s.io/v1\",\"kind\":\"Event\",\"verb\":\"watch\",\"user\":\"u6\"}",
      "{\"apiVersion\":\"audit.k8s.io/v1\",\"kind\":\"Event\",\"verb\":\"get\",\"user\":\"u7\"}",
      "{\"apiVersion\":\"audit.k8s.io/v1\",\"kind\":\"Event\",\"verb\":\"post\",\"user\":\"u8\"}",
      "{\"apiVersion\":\"audit.k8s.io/v1\",\"kind\":\"Event\",\"verb\":\"get\",\"user\":\"u9\"}",
      "{\"apiVersion\":\"audit.k8s.io/v1\",\"kind\":\"Event\",\"verb\":\"get\",\"user\":\"u10\"}",
      "{\"apiVersion\":\"audit.k8s.io/v1\",\"kind\":\"Event\",\"verb\":\"post\",\"user\":\"u11\"}",
      "{\"apiVersion\":\"audit.k8s.io/v1\",\"kind\":\"Event\",\"verb\":\"get\",\"user\":\"u12\"}"
    ],
    "privacy_mode": true,
    "min_sample_count": 5,
    "min_events": 5
  },
  "expected": {
    "findings_count_min": 1,
    "headline_must_match": "constant",
    "rubric": "Tool should detect at least one constant slot (apiVersion and/or kind are present in 100% of events). Findings[0].constantSlots should include slots with distinct_count = 1, sample_count >= 10."
  }
}